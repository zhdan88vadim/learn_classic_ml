# Сигмоида
x_line = np.linspace(X.min(), X.max(), 100)
z_line = w[0, 0] * x_line + b[0, 0]
y_prob_line = sigmoid(z_line)
ax1.plot(x_line, y_prob_line, color='green', linewidth=4, label='Сигмоида (P(y=1|x))')
